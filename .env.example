# Yahoo Fantasy API credentials
# Get these from https://developer.yahoo.com/apps/
YAHOO_CLIENT_ID=your_client_id_here
YAHOO_CLIENT_SECRET=your_client_secret_here

# Your Yahoo Fantasy League ID
# Found in your league URL: https://baseball.fantasysports.yahoo.com/b1/YOUR_LEAGUE_ID
YAHOO_LEAGUE_ID=your_league_id_here

# Season year
YAHOO_GAME_CODE=mlb
YAHOO_SEASON=2026

# Anthropic API key for writing summaries
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
